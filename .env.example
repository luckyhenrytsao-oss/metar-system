.env.example

# ============================================================
# METAR 高频采集与分发系统 —— 环境变量模板
# 用法：复制本文件为 .env，填入真实值后启动容器。
#       cp .env.example .env
# ============================================================

# Redis 连接地址（Docker Compose 内网使用 redis://redis:6379/0）
REDIS_URL=redis://redis:6379/0

# 监控机场列表（逗号分隔 ICAO 代码）
# 默认已包含 M1 项目的 49 个机场，可按需覆盖：
# MONITOR_AIRPORTS=KJFK,VHHH,EGLL

# 采集轮询间隔（秒），必须在 1.0 ~ 2.0 之间
POLL_INTERVAL_SECONDS=1.5

# Redis 中 METAR 数据 TTL（秒），默认 7200（2 小时）
METAR_TTL_SECONDS=7200

# 请求头 User-Agent，必须包含可联系的邮箱，否则可能被数据源 403
# ⚠️ 请替换为你的真实邮箱
USER_AGENT=MyMetarApp/1.0 (htsao2000@gmail.com)

# weather.gov / SynopticData 独立 Token（可选但推荐生产使用）
# 未配置时会自动抓取 weather.gov 内嵌 Token，稳定性较低
# WEATHERGOV_TOKEN=your_synopticdata_token_here

# HTTP 请求超时（秒）
HTTP_TIMEOUT=15.0

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
